NAME graphblas
VERSION 7.8.3
SYSTEM_LIBS ALLOW
SOURCE URL https://github.com/DrTimothyAldenDavis/SuiteSparse/archive/refs/tags/v7.8.3.tar.gz
BUILD_SYSTEM CMAKE
CMAKE_DEFINE SUITESPARSE_ENABLE_PROJECTS=graphblas
CMAKE_DEFINE SUITESPARSE_USE_CUDA=OFF
CMAKE_DEFINE BUILD_SHARED_LIBS=OFF
CMAKE_DEFINE BUILD_TESTING=OFF
CMAKE_DEFINE BUILD_STATIC_LIBS=ON
TARGET graphblas::graphblas STATIC lib/libgraphblas.a INTERFACE include
LINK graphblas::graphblas gomp m
