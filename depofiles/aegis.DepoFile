NAME aegis
VERSION 0.10.1
SOURCE URL https://github.com/aegis-aead/libaegis/archive/refs/tags/0.10.1.tar.gz
BUILD_SYSTEM CMAKE
CMAKE_DEFINE CMAKE_INSTALL_INCLUDEDIR=include/aegis
CMAKE_ARG "-DCMAKE_C_FLAGS=-mavx512f -mvaes"
TARGET aegis::aegis STATIC lib/libaegis.a INTERFACE include
