NAME snappy
VERSION 1.2.2
SYSTEM_LIBS ALLOW
SOURCE URL https://github.com/google/snappy/archive/refs/tags/1.2.2.tar.gz
BUILD_SYSTEM CMAKE
CMAKE_DEFINE BUILD_SHARED_LIBS=OFF
CMAKE_DEFINE SNAPPY_BUILD_TESTS=OFF
CMAKE_DEFINE SNAPPY_BUILD_BENCHMARKS=OFF
TARGET snappy::snappy STATIC lib/libsnappy.a INTERFACE include
