FROM scratch for @PRODIGY_RESOLVED_TARGET_ARCH@
COPY {probe} ./@PRODIGY_PINGPONG_PROBE_BINARY@ /app/prodigy_pingpong_container
COPY {ebpf} ./container.egress.router.ebpf.o /root/prodigy/container.egress.router.ebpf.o
COPY {ebpf} ./container.ingress.router.ebpf.o /root/prodigy/container.ingress.router.ebpf.o
SURVIVE /app/prodigy_pingpong_container
SURVIVE /root/prodigy
EXECUTE ["/app/prodigy_pingpong_container"]
